{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["uploads/**", "models/**", "utils/**", "seed-data.js"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/uploads/(.*)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/uploads/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
